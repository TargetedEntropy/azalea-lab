FROM eclipse-temurin:21-jdk AS installer

WORKDIR /server

# Copy only the installer jar for NeoForge installation (cached layer)
COPY DynamicOdyssey-Server-2.7.0/neoforge-21.1.219-installer.jar .

# Run the NeoForge installer at build time
RUN java -jar neoforge-21.1.219-installer.jar --installServer && \
    rm -f neoforge-21.1.219-installer.jar

# --- Patch stage: bypass NeoForge channel negotiation ---
# This allows non-NeoForge clients (azalea bot) to connect
COPY NegotiationPatch.java /tmp/patch/net/neoforged/neoforge/network/negotiation/NetworkComponentNegotiator.java
COPY ConfigInitPatch.java /tmp/patch/net/neoforged/neoforge/network/ConfigurationInitialization.java

RUN CP=$(find /server/libraries -name "*.jar" | tr "\n" ":") && \
    javac -proc:none -cp "$CP" \
        /tmp/patch/net/neoforged/neoforge/network/negotiation/NetworkComponentNegotiator.java \
        /tmp/patch/net/neoforged/neoforge/network/ConfigurationInitialization.java && \
    cd /tmp/patch && \
    jar uf /server/libraries/net/neoforged/neoforge/21.1.219/neoforge-21.1.219-universal.jar \
        net/neoforged/neoforge/network/negotiation/NetworkComponentNegotiator.class \
        'net/neoforged/neoforge/network/negotiation/NetworkComponentNegotiator$ComponentNegotiationResult.class' \
        net/neoforged/neoforge/network/ConfigurationInitialization.class && \
    rm -rf /tmp/patch

# --- Runtime stage ---
FROM eclipse-temurin:21-jdk

WORKDIR /server

# Copy installed NeoForge libraries from installer stage (with patch applied)
COPY --from=installer /server /server

# Copy the rest of the pack (mods, config, etc.) - separate layer for faster rebuilds
COPY DynamicOdyssey-Server-2.7.0/mods/ /server/mods/
# Add coremod to bypass checkPacket validation for non-NeoForge clients
COPY checkpatch-coremod-1.0.0.jar /server/mods/checkpatch-coremod-1.0.0.jar
COPY DynamicOdyssey-Server-2.7.0/config/ /server/config/
COPY DynamicOdyssey-Server-2.7.0/defaultconfigs/ /server/defaultconfigs/
COPY DynamicOdyssey-Server-2.7.0/kubejs/ /server/kubejs/
COPY DynamicOdyssey-Server-2.7.0/plugins/ /server/plugins/
COPY DynamicOdyssey-Server-2.7.0/user_jvm_args.txt /server/user_jvm_args.txt
COPY DynamicOdyssey-Server-2.7.0/packwiz.json /server/packwiz.json

# Copy our custom server.properties and log4j2 config
COPY DynamicOdyssey-Server-2.7.0/server.properties /server/server.properties
COPY DynamicOdyssey-Server-2.7.0/log4j2.xml /server/log4j2.xml

# Accept EULA
RUN echo "eula=true" > eula.txt

EXPOSE 25565

# Entrypoint: run.sh is generated by the NeoForge installer
CMD ["bash", "run.sh"]
